{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plato claim record",
  "type": "object",
  "required": ["id", "statement", "claim_layer", "supporting_card_ids", "limit_note"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "statement": {"type": "string", "minLength": 12},
    "claim_layer": {"enum": ["textual-observation", "contextual-inference", "interpretive-boundary", "reception"]},
    "supporting_card_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "limit_note": {"type": "string", "minLength": 10}
  },
  "additionalProperties": false
}
