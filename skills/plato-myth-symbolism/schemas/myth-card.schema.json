{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plato myth or image card",
  "type": "object",
  "required": ["id", "title", "dialogue", "book", "stephanus", "speaker", "audience", "narrative_status", "argument_context", "primary_source_id", "analysis_prompts", "non_claims"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "title": {"type": "string", "minLength": 1},
    "dialogue": {"type": "string", "minLength": 1},
    "book": {"type": "string"},
    "stephanus": {"type": "object", "required": ["start", "end"], "properties": {"start": {"type": "string", "minLength": 2}, "end": {"type": "string", "minLength": 2}}, "additionalProperties": false},
    "speaker": {"type": "string", "minLength": 1},
    "audience": {"type": "string", "minLength": 1},
    "narrative_status": {"type": "string", "minLength": 1},
    "argument_context": {"type": "string", "minLength": 20},
    "primary_source_id": {"type": "string"},
    "analysis_prompts": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 10}},
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 8}}
  },
  "additionalProperties": false
}
