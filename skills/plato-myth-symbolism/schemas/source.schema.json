{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plato source record",
  "type": "object",
  "required": ["id", "title", "work", "kind", "uri", "license_notice", "reuse_policy", "accessed"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "title": {"type": "string", "minLength": 1},
    "work": {"type": "string", "minLength": 1},
    "kind": {"type": "string", "minLength": 1},
    "uri": {"type": "string", "format": "uri"},
    "license_notice": {"type": "string", "minLength": 1},
    "reuse_policy": {"type": "string", "minLength": 1},
    "accessed": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
  },
  "additionalProperties": false
}
